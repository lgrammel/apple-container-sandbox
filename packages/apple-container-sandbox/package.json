{
  "name": "@lgrammel/apple-container-sandbox",
  "version": "0.0.0",
  "description": "AI SDK sandbox provider backed by Apple Container Sandboxes.",
  "homepage": "https://github.com/lgrammel/npm-container-sandbox/tree/main/packages/apple-container-sandbox#readme",
  "bugs": {
    "url": "https://github.com/lgrammel/npm-container-sandbox/issues"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lgrammel/npm-container-sandbox.git",
    "directory": "packages/apple-container-sandbox"
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo",
    "src",
    "README.md",
    "REQUIREMENTS.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "test": "pnpm run test:unit && pnpm run test:types",
    "test:types": "pnpm run build && vitest run --config vitest.config.ts --typecheck.only",
    "test:unit": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/harness": "^1.0.10"
  },
  "devDependencies": {
    "@types/json-schema": "7.0.15"
  },
  "engines": {
    "node": ">=22"
  }
}
