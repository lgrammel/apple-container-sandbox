{
  "name": "apple-container-sandbox-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "changeset": "changeset",
    "example": "pnpm --filter example start",
    "example:codex": "pnpm --filter codex-example start",
    "example:tool": "pnpm --filter tool-example start",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "pack:package": "pnpm --filter @lgrammel/apple-container-sandbox pack",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "test": "pnpm --recursive test",
    "typecheck": "pnpm --filter @lgrammel/apple-container-sandbox build && pnpm --recursive --if-present typecheck",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0"
}
